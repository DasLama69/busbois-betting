# Bus Bois Betting — Environment Configuration
# This file documents the required environment variables.
# To configure credentials: copy config.example.js to config.js and fill in your values.
# config.js is listed in .gitignore and must not be committed to the repository.

# Required variables (set in config.js as window.BBB_CONFIG):
#   SUPABASE_URL      — your Supabase project URL
#   SUPABASE_ANON_KEY — your Supabase anon/publishable key
